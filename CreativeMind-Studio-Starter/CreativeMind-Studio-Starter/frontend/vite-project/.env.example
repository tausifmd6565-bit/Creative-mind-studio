# ─────────────────────────────────────────────────────────────────────────────
# CreativeMind Studio — Frontend environment variables
# Copy to .env.local and fill in your values.
#
# SECURITY RULES:
#  - Only variables prefixed with VITE_ are embedded in the browser bundle.
#  - NEVER put API keys, private tokens, or secrets as VITE_* variables.
#    They will be readable by anyone who views the JS bundle.
#  - AI provider keys (OpenAI, Anthropic, etc.) must live on the backend server
#    only. All AI requests are routed through the backend API (/api/...).
#  - Backend database URLs, service credentials, and signing secrets must
#    NEVER appear in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Configuration ─────────────────────────────────────────────────────────

# Base URL for the backend REST API.
# The /api/v1 prefix is included — do NOT add it again in client code.
# Must use https:// in production.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Set to "true" to serve all requests from local mock adapters instead of the real backend.
# Every service checks this flag and swaps to its mock adapter automatically.
# UI code never needs to change.
VITE_USE_MOCK_API=true

# Default request timeout in milliseconds.
VITE_API_TIMEOUT_MS=15000

# Maximum number of retries for safe GET requests before giving up.
VITE_API_MAX_RETRIES=3

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Enable analytics workspace
VITE_FEATURE_ANALYTICS=true

# Enable virality twin workspace
VITE_FEATURE_VIRALITY=true

# ─────────────────────────────────────────────────────────────────────────────
# Variables that must NEVER appear in .env.example or any committed .env file:
#
#  OPENAI_API_KEY          ← backend only
#  ANTHROPIC_API_KEY       ← backend only
#  DATABASE_URL            ← backend only
#  JWT_SECRET              ← backend only
#  STRIPE_SECRET_KEY       ← backend only
#  SENDGRID_API_KEY        ← backend only
#  AWS_SECRET_ACCESS_KEY   ← backend only
#  REDIS_URL               ← backend only
# ─────────────────────────────────────────────────────────────────────────────
