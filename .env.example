# ==============================================================================
# CreativeMind Studio - Silent Killer Backend
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# IBM watsonx.ai - Required for all Granite agent calls
# ------------------------------------------------------------------------------

# Your IBM Cloud API key
# Get it at: https://cloud.ibm.com/iam/apikeys -> Create an IBM Cloud API key
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID
# Get it at: watsonx.ai -> Projects -> your project -> Manage tab -> Project ID
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Regional API endpoint — NOT the browser dashboard URL
# Use:  https://us-south.ml.cloud.ibm.com   (US South - most common)
#       https://eu-de.ml.cloud.ibm.com       (EU Frankfurt)
#       https://jp-tok.ml.cloud.ibm.com      (AP Tokyo)
# Do NOT use: https://dataplatform.cloud.ibm.com/wx/home (that is the dashboard)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model ID — must be available in your watsonx.ai environment
# Recommended: ibm/granite-4-h-small (fast, modern, strong JSON following)
WATSONX_MODEL_ID=ibm/granite-4-h-small

# Max seconds to wait for a single Granite call before raising a timeout error
GRANITE_TIMEOUT_SECONDS=60

# Max new tokens per Granite response
GRANITE_MAX_NEW_TOKENS=1024

# Sampling temperature (0.0 = deterministic, 1.0 = highly creative)
GRANITE_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# Supabase / PostgreSQL - Required for all data persistence
# ------------------------------------------------------------------------------

# Supabase project URL
# Get it at: Supabase dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — has full DB access, never expose client-side
# Get it at: Supabase dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Async PostgreSQL connection string for the application (must have +asyncpg driver)
# Get it at: Supabase -> Settings -> Database -> Connection pooling -> Session mode
# Replace [YOUR-PASSWORD] with your actual database password
# Format: postgresql+asyncpg://postgres.<ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Synchronous PostgreSQL URL for Alembic migrations (no +asyncpg driver prefix)
# Same as DATABASE_URL but with postgresql:// instead of postgresql+asyncpg://
DATABASE_URL_SYNC=postgresql://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------

# Runtime environment: development | staging | production
APP_ENV=development

# Enable verbose SQLAlchemy query logging (set false in production)
DEBUG=true

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Application version — surfaced in GET /health and OpenAPI /docs
APP_VERSION=0.1.0
